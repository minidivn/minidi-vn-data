[
  {
    "name": "wikidata",
    "description": "WikiData — open knowledge graph with structured data about the world",
    "version": "1.0.0",
    "endpoint": "https://query.wikidata.org/sparql",
    "entity_types": [
      "place",
      "person",
      "event",
      "concept",
      "organization",
      "artifact"
    ],
    "properties": [
      "P150 (contains admin division)",
      "P131 (located in)",
      "P17 (country)",
      "P31 (instance of)",
      "P580 (start time)",
      "P585 (point in time)",
      "P569 (date of birth)",
      "P106 (occupation)",
      "P625 (coordinate location)"
    ],
    "metadata_fields": {
      "start_time": "ISO start date",
      "birth_date": "ISO birth date",
      "point_in_time": "ISO date of event",
      "death_date": "ISO death date",
      "occupation": "Occupation label",
      "end_time": "ISO end date",
      "coordinates": "Geo: latitude/longitude"
    },
    "attribution": "CC0 — WikiData contributors"
  },
  {
    "name": "wikipedia",
    "description": "Wikipedia — free encyclopedia articles with rich text summaries",
    "version": "0.1.0",
    "endpoint": "https://en.wikipedia.org/w/api.php",
    "entity_types": [
      "article",
      "category"
    ],
    "properties": [
      "links_to",
      "category_member"
    ],
    "metadata_fields": {
      "page_id": "Numeric Wikipedia page ID",
      "url": "Full article URL",
      "summary": "First paragraph of article"
    },
    "attribution": "CC-BY-SA — Wikipedia contributors"
  },
  {
    "name": "openstreetmap",
    "description": "OpenStreetMap — editable world map with geographic features and tags",
    "version": "0.1.0",
    "endpoint": "https://overpass-api.de/api/interpreter",
    "entity_types": [
      "node",
      "way",
      "relation",
      "amenity",
      "natural"
    ],
    "properties": [
      "connected_to",
      "member_of",
      "adjacent_to"
    ],
    "metadata_fields": {
      "tags": "OSM key-value tags",
      "lat": "Latitude",
      "lon": "Longitude"
    },
    "attribution": "ODbL — OpenStreetMap contributors"
  }
